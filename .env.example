# Copy to .env and fill in. Get a free key at https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash
# For the eval harness (many calls) you can use the higher-rate-limit lite model:
# LLM_MODEL=gemini-2.5-flash-lite
USE_EMBEDDINGS=false
